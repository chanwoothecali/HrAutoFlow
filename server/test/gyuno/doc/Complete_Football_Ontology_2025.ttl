@prefix : <http://www.semanticweb.org/yujun/ontologies/2025/10/ontology-project#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@base <http://www.semanticweb.org/yujun/ontologies/2025/10/ontology-project> .

<http://www.semanticweb.org/yujun/ontologies/2025/10/ontology-project> rdf:type owl:Ontology ;
    rdfs:label "Football Transfer Market Ontology 2025"@en ;
    rdfs:comment "축구 이적시장 온톨로지 - 2025년 기준"@ko .

#################################################################
#    Object Properties
#################################################################

###  이적 관련 핵심 Object Properties

:transferredFrom rdf:type owl:ObjectProperty ;
    rdfs:domain :Transfer ;
    rdfs:range :Club ;
    rdfs:comment "이적 출발 클럽"@ko .

:transferredTo rdf:type owl:ObjectProperty ;
    rdfs:domain :Transfer ;
    rdfs:range :Club ;
    rdfs:comment "이적 도착 클럽"@ko .

:involvesPlayer rdf:type owl:ObjectProperty ;
    rdfs:domain :Transfer ;
    rdfs:range :Player ;
    rdfs:comment "이적에 관련된 선수"@ko .

:involvesClub rdf:type owl:ObjectProperty ;
    rdfs:domain :Transfer ;
    rdfs:range :Club .

:involvedIn rdf:type owl:ObjectProperty ;
    rdfs:domain :Player ;
    rdfs:range :Transfer ;
    owl:inverseOf :involvesPlayer ;
    rdfs:comment "선수가 참여한 이적"@ko .

###  클럽 관련 Object Properties

:belongsToLeague rdf:type owl:ObjectProperty ;
    rdfs:domain :Club ;
    rdfs:range :League ;
    rdfs:comment "클럽 소속 리그"@ko .

:locatedIn rdf:type owl:ObjectProperty ;
    rdfs:domain :Club ;
    rdfs:range :City ;
    rdfs:comment "클럽 위치"@ko .

:isRivalClub rdf:type owl:ObjectProperty ;
    rdf:type owl:SymmetricProperty ;
    rdfs:domain :Club ;
    rdfs:range :Club ;
    rdfs:comment "라이벌 클럽 관계"@ko .

:hasCaptain rdf:type owl:ObjectProperty ;
    rdfs:domain :Club ;
    rdfs:range :Player ;
    rdfs:comment "클럽의 주장"@ko .

:hasManager rdf:type owl:ObjectProperty ;
    rdfs:domain :Club ;
    rdfs:range :Manager ;
    rdfs:comment "클럽의 감독"@ko .

###  선수 관련 Object Properties

:playsFor rdf:type owl:ObjectProperty ;
    rdfs:domain :Player ;
    rdfs:range :Club ;
    rdfs:comment "선수 소속 클럽"@ko .

:playsAs rdf:type owl:ObjectProperty ;
    rdfs:domain :Player ;
    rdfs:range :Position ;
    rdfs:comment "선수 포지션"@ko .

:nationalityOf rdf:type owl:ObjectProperty ;
    rdfs:domain :Player ;
    rdfs:range :Country ;
    rdfs:comment "선수 국적"@ko .

:hasContract rdf:type owl:ObjectProperty ;
    rdfs:domain :Player ;
    rdfs:range :Contract .

:representedBy rdf:type owl:ObjectProperty ;
    rdfs:domain :Player ;
    rdfs:range :Agent ;
    rdfs:comment "선수 에이전트"@ko .

###  계약 관련 Object Properties

:hasClause rdf:type owl:ObjectProperty ;
    rdfs:domain :Contract ;
    rdfs:range :Clause ;
    rdfs:comment "계약 조항"@ko .

###  에이전트 관련 Object Properties

:handledTransfer rdf:type owl:ObjectProperty ;
    rdfs:domain :Agent ;
    rdfs:range :Transfer ;
    rdfs:comment "에이전트가 처리한 이적"@ko .

###  감독 관련 Object Properties

:worksFor rdf:type owl:ObjectProperty ;
    rdfs:domain :Manager ;
    rdfs:range :Club .

:influencedTransfers rdf:type owl:ObjectProperty ;
    rdfs:domain :Manager ;
    rdfs:range :Transfer .

###  이적 시즌/윈도우 관련

:inSeason rdf:type owl:ObjectProperty ;
    rdfs:domain :Transfer ;
    rdfs:range :Season .

:inWindow rdf:type owl:ObjectProperty ;
    rdfs:domain :Transfer ;
    rdfs:range :TransferWindow .

###  리그 관련

:hasTransfers rdf:type owl:ObjectProperty ;
    rdfs:domain :League ;
    rdfs:range :Transfer .

#################################################################
#    Data Properties
#################################################################

###  이적 관련 Data Properties

:hasFee rdf:type owl:DatatypeProperty ;
    rdfs:domain :Transfer ;
    rdfs:range xsd:decimal ;
    rdfs:comment "이적료 (EUR)"@ko .

:signingDate rdf:type owl:DatatypeProperty ;
    rdfs:domain :Transfer ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "이적 계약 날짜"@ko .

:isLoan rdf:type owl:DatatypeProperty ;
    rdfs:domain :Transfer ;
    rdfs:range xsd:boolean ;
    rdfs:comment "임대 여부"@ko .

:hasOptionToBuy rdf:type owl:DatatypeProperty ;
    rdfs:domain :Transfer ;
    rdfs:range xsd:boolean ;
    rdfs:comment "임대 후 매수 옵션"@ko .

:isFreeTransfer rdf:type owl:DatatypeProperty ;
    rdfs:domain :Transfer ;
    rdfs:range xsd:boolean ;
    rdfs:comment "자유이적 여부"@ko .

:loanFee rdf:type owl:DatatypeProperty ;
    rdfs:domain :Transfer ;
    rdfs:range xsd:decimal ;
    rdfs:comment "임대료"@ko .

:buyoutClauseAmount rdf:type owl:DatatypeProperty ;
    rdfs:domain :Transfer ;
    rdfs:range xsd:decimal ;
    rdfs:comment "바이아웃 조항 금액"@ko .

###  선수 관련 Data Properties

:playerAge rdf:type owl:DatatypeProperty ;
    rdfs:domain :Player ;
    rdfs:range xsd:integer ;
    rdfs:comment "선수 나이"@ko .

:playerName rdf:type owl:DatatypeProperty ;
    rdfs:domain :Player ;
    rdfs:range xsd:string .

:marketValue rdf:type owl:DatatypeProperty ;
    rdfs:domain :Player ;
    rdfs:range xsd:decimal ;
    rdfs:comment "선수 시장가치"@ko .

:goalsScored rdf:type owl:DatatypeProperty ;
    rdfs:domain :Player ;
    rdfs:range xsd:integer .

:hasAssists rdf:type owl:DatatypeProperty ;
    rdfs:domain :Player ;
    rdfs:range xsd:integer .

:shirtNumber rdf:type owl:DatatypeProperty ;
    rdfs:domain :Player ;
    rdfs:range xsd:integer .

###  계약 관련 Data Properties

:contractDuration rdf:type owl:DatatypeProperty ;
    rdfs:domain :Contract ;
    rdfs:range xsd:integer ;
    rdfs:comment "계약 기간 (년)"@ko .

:salary rdf:type owl:DatatypeProperty ;
    rdfs:domain :Contract ;
    rdfs:range xsd:decimal ;
    rdfs:comment "연봉"@ko .

:contractStartDate rdf:type owl:DatatypeProperty ;
    rdfs:domain :Contract ;
    rdfs:range xsd:date .

:contractEndDate rdf:type owl:DatatypeProperty ;
    rdfs:domain :Contract ;
    rdfs:range xsd:date .

###  클럽 관련 Data Properties

:clubName rdf:type owl:DatatypeProperty ;
    rdfs:domain :Club ;
    rdfs:range xsd:string .

:foundedYear rdf:type owl:DatatypeProperty ;
    rdfs:domain :Club ;
    rdfs:range xsd:integer .

###  리그 관련 Data Properties

:leagueName rdf:type owl:DatatypeProperty ;
    rdfs:domain :League ;
    rdfs:range xsd:string .

:isTop5League rdf:type owl:DatatypeProperty ;
    rdfs:domain :League ;
    rdfs:range xsd:boolean .

#################################################################
#    Classes
#################################################################

###  핵심 클래스

:Person rdf:type owl:Class .

:Organization rdf:type owl:Class .

:Event rdf:type owl:Class .

:Place rdf:type owl:Class .

###  Person 하위 클래스

:Player rdf:type owl:Class ;
    rdfs:subClassOf :Person ;
    rdfs:comment "축구 선수"@ko .

:Manager rdf:type owl:Class ;
    rdfs:subClassOf :Person ;
    rdfs:comment "감독"@ko .

:Agent rdf:type owl:Class ;
    rdfs:subClassOf :Person ;
    rdfs:comment "에이전트"@ko .

###  Organization 하위 클래스

:Club rdf:type owl:Class ;
    rdfs:subClassOf :Organization ;
    rdfs:comment "축구 클럽"@ko .

:League rdf:type owl:Class ;
    rdfs:subClassOf :Organization ;
    rdfs:comment "축구 리그"@ko .

###  Event 하위 클래스

:Transfer rdf:type owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:comment "이적 이벤트"@ko .

:PermanentTransfer rdf:type owl:Class ;
    rdfs:subClassOf :Transfer ;
    rdfs:comment "완전 이적"@ko .

:LoanTransfer rdf:type owl:Class ;
    rdfs:subClassOf :Transfer ;
    rdfs:comment "임대 이적"@ko .

:Contract rdf:type owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:comment "계약"@ko .

###  Place 하위 클래스

:Country rdf:type owl:Class ;
    rdfs:subClassOf :Place .

:City rdf:type owl:Class ;
    rdfs:subClassOf :Place .

###  기타 클래스

:Position rdf:type owl:Class ;
    rdfs:comment "선수 포지션"@ko .

:Clause rdf:type owl:Class ;
    rdfs:comment "계약 조항"@ko .

:Season rdf:type owl:Class ;
    rdfs:comment "시즌"@ko .

:TransferWindow rdf:type owl:Class ;
    rdfs:comment "이적 시장 기간"@ko .

#################################################################
#    Individuals - Positions
#################################################################

:GoalkeeperPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Goalkeeper"@en , "골키퍼"@ko .

:DefenderPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Defender"@en , "수비수"@ko .

:MidfielderPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Midfielder"@en , "미드필더"@ko .

:ForwardPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Forward"@en , "공격수"@ko .

:LeftBackPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Left Back"@en , "좌측백"@ko .

:RightBackPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Right Back"@en , "우측백"@ko .

:CenterBackPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Center Back"@en , "센터백"@ko .

:DefensiveMidfielderPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Defensive Midfielder"@en , "수비형 미드필더"@ko .

:AttackingMidfielderPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Attacking Midfielder"@en , "공격형 미드필더"@ko .

:WingerPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Winger"@en , "윙어"@ko .

:StrikerPosition rdf:type owl:NamedIndividual , :Position ;
    rdfs:label "Striker"@en , "스트라이커"@ko .

#################################################################
#    Individuals - Leagues
#################################################################

:PremierLeague rdf:type owl:NamedIndividual , :League ;
    :leagueName "Premier League" ;
    :isTop5League true ;
    rdfs:label "프리미어리그"@ko .

:LaLiga rdf:type owl:NamedIndividual , :League ;
    :leagueName "La Liga" ;
    :isTop5League true ;
    rdfs:label "라리가"@ko .

:Bundesliga rdf:type owl:NamedIndividual , :League ;
    :leagueName "Bundesliga" ;
    :isTop5League true ;
    rdfs:label "분데스리가"@ko .

:SerieA rdf:type owl:NamedIndividual , :League ;
    :leagueName "Serie A" ;
    :isTop5League true ;
    rdfs:label "세리에A"@ko .

:Ligue1 rdf:type owl:NamedIndividual , :League ;
    :leagueName "Ligue 1" ;
    :isTop5League true ;
    rdfs:label "리그1"@ko .

:Eredivisie rdf:type owl:NamedIndividual , :League ;
    :leagueName "Eredivisie" ;
    :isTop5League false .

:SaudiProLeague rdf:type owl:NamedIndividual , :League ;
    :leagueName "Saudi Pro League" ;
    :isTop5League false .

:Championship rdf:type owl:NamedIndividual , :League ;
    :leagueName "EFL Championship" ;
    :isTop5League false .

:ScottishPremiership rdf:type owl:NamedIndividual , :League ;
    :leagueName "Scottish Premiership" ;
    :isTop5League false .

:SuperLig rdf:type owl:NamedIndividual , :League ;
    :leagueName "Turkish Super Lig" ;
    :isTop5League false .

:GreekSuperLeague rdf:type owl:NamedIndividual , :League ;
    :leagueName "Greek Super League" ;
    :isTop5League false .

:SerbianSuperLiga rdf:type owl:NamedIndividual , :League ;
    :leagueName "Serbian Super Liga" ;
    :isTop5League false .

